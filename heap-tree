export module Heap;
#include <iostream>
#include <vector>

using namespace std;

template<typename T>
class Heap { // 1-based
private:
    int sz;
    vector<T> tree;
    void heapify(int idx) {
        int mx = idx;
        int l = idx*2; int r=idx*2 + 1;
        if (l<=sz && tree[l]>tree[mx]) mx = l;
        if (r<=sz && tree[r]>tree[mx]) mx = r;
        if (mx!=idx) {
            swap(tree[idx],tree[mx]);
            heapify(mx);
        }
    }
    void build() {
        for (int i = sz/2;i>0;i--) {
            heapify(i);
        }
    }
public:
    // must recieved 1-based array;
    Heap(vector<T> &array) {
        sz = array.size()-1;
        tree = array;
        build();
    }
    void remove(int idx) {
        if (idx<1 || idx>sz) throw runtime_error("Non Valid Index");
        swap(tree[idx],tree[sz]);
        tree.pop_back(); sz--;
        heapify(idx);
    }
    T getMax() const { return tree[1];}
    T extraxtMax() {
        if (sz < 1) throw runtime_error("Heap empty");
        T maxVal = tree[1];
        tree[1] = tree[sz];
        tree.pop_back(); sz--;
        if (sz > 0) heapify(1);
        return maxVal;
    }
    vector<T> getSorted() {
        vector<T> ret;
        while (sz>0) ret.push_back(extraxtMax());
        return ret;
    }

};
